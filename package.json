{
  "name": "fakebuster-mern",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev": "concurrently \"npm run dev:ml\" \"npm run dev:api\" \"npm run dev:client\"",
    "dev:ml": ".\\venv\\Scripts\\python.exe ml-service\\app.py",
